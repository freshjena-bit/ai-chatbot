# ===================================
# API Keys for different AI models
# Add your API keys below to enable each model
# The first available model will be automatically selected
# ===================================

# Google Gemini API Key (Gemini 2.5 Flash)
# Get yours at: https://aistudio.google.com/app/apikey
# Supports: Text, Image, and Code generation
GEMINI_API_KEY=

# OpenAI API Keys
# Get yours at: https://platform.openai.com/api-keys
# GPT-4 Turbo - Text and Code generation
OPENAI_API_KEY=

# DALL-E 3 uses the same OpenAI key
# DALLE_API_KEY is same as OPENAI_API_KEY

# Anthropic Claude API Key (Claude 3.5 Sonnet)
# Get yours at: https://console.anthropic.com/
# Supports: Text and Code generation
ANTHROPIC_API_KEY=

# Meta Llama API Key (Llama 3.1 405B)
# Get yours at: https://replicate.com/ or https://together.ai/
# Supports: Text and Code generation
LLAMA_API_KEY=

# Stability AI API Key (Stable Diffusion XL)
# Get yours at: https://platform.stability.ai/
# Supports: Image generation
# STABILITY_API_KEY=

# xAI Grok API Key
# Get yours at: https://console.x.ai/
# Supports: Text generation only
XAI_API_KEY=
